{
  "redirects": [
    {
      "source": "/cpanel",
      "destination": "https://cpanel.utilcar.cl:2083",
      "statusCode": 307
    },
    {
      "source": "/webmail",
      "destination": "https://webmail.utilcar.cl",
      "statusCode": 307
    },
    {
      "source": "/whm",
      "destination": "https://whm.utilcar.cl:2087",
      "statusCode": 307
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/cms/home-isr.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=60, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}