# URL pública del sitio (canonical, Open Graph, sitemap)
VITE_SITE_URL=https://www.utilcar.cl

# Contacto (formulario + datos públicos)
VITE_WHATSAPP_NUMBER=56942868395
VITE_CONTACT_EMAIL=contacto@utilcar.cl

# Resend — envío de correos del formulario de contacto (solo servidor / Vercel)
RESEND_API_KEY=re_xxxxxxxx
# Remitente verificado en Resend (dominio utilcar.cl o onboarding@resend.dev en pruebas)
RESEND_FROM_EMAIL=Utilcar <onboarding@resend.dev>
# Sandbox Resend: true = forzar RESEND_TEST_RECIPIENT | false = usar siteSettings.contactEmail (producción)
RESEND_SANDBOX_MODE=false
RESEND_TEST_RECIPIENT=julioignaciorodriguez97@gmail.com

# Sanity CMS (opcional — sin configurar usa solo /content)
# Guía: docs/SANITY_INTEGRACION.md
VITE_USE_SANITY=false
VITE_SANITY_PROJECT_ID=1k8yld2r
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-05-28
VITE_SANITY_USE_CDN=true

# Transición especialidades: false = legacy | true = specialtiesNew (+ merge seguro)
VITE_USE_NEW_SPECIALTIES=false

# Block Resolver Layer (homePage.blocks[] → extensions)
VITE_USE_BLOCK_RESOLVER=false
# Especialidades V2: categories[] CMS-first (requiere VITE_USE_BLOCK_RESOLVER=true)
VITE_USE_SPECIALTIES_V2=false

# Page Builder universal (aboutPage, workPage, contactPage, serviceSubPage blocks[])
VITE_USE_PAGE_RESOLVER=false
VITE_USE_SERVICES_V2=false
VITE_USE_WORK_V2=true
VITE_USE_CONTACT_V2=true
VITE_USE_ABOUT_V2=true

# Runtime debug logs [utilcar runtime:*] [utilcar assets:*] — false en producción
VITE_RUNTIME_DEBUG=false

# Smoke test: npm run cms:smoke
# Studio + seed: utilcar-web/utilcar-studio/ (npm run seed con SANITY_API_TOKEN)
