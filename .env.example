# URL pública del sitio (canonical, Open Graph, sitemap)
VITE_SITE_URL=https://www.utilcar.cl

# Contacto (formulario futuro + datos públicos)
VITE_WHATSAPP_NUMBER=56942868395
VITE_CONTACT_EMAIL=contacto@utilcar.cl

# Sanity CMS (opcional — sin configurar usa solo /content)
# Guía: docs/SANITY_INTEGRACION.md
VITE_USE_SANITY=false
VITE_SANITY_PROJECT_ID=1k8yld2r
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-05-28
VITE_SANITY_USE_CDN=true

# Transición especialidades: false = legacy | true = specialtiesNew (+ merge seguro)
VITE_USE_NEW_SPECIALTIES=false

# Block Resolver Layer (homePage.blocks[] → extensions)
VITE_USE_BLOCK_RESOLVER=false
# Especialidades V2: categories[] CMS-first (requiere VITE_USE_BLOCK_RESOLVER=true)
VITE_USE_SPECIALTIES_V2=false

# Page Builder universal (servicesPage, workPage, contactPage blocks[])
VITE_USE_PAGE_RESOLVER=false
VITE_USE_SERVICES_V2=false
VITE_USE_WORK_V2=false
VITE_USE_CONTACT_V2=false

# Runtime debug logs [utilcar runtime:*] [utilcar assets:*]
VITE_RUNTIME_DEBUG=true

# Smoke test: npm run cms:smoke
# Studio + seed: ../utilcar-studio (npm run seed con SANITY_API_TOKEN)
